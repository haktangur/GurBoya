@model List<GurBoya.Models.Siparis>
@{
    ViewData["Title"] = "Siparişler";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Siparişler</h2>
    <a asp-action="Create" class="btn btn-primary">+ Yeni Sipariş</a>
</div>

@if (TempData["Basari"] != null)
{
    <div class="alert alert-success">@TempData["Basari"]</div>
}

<table class="table table-hover table-bordered">
    <thead class="table-dark">
        <tr>
            <th>#</th>
            <th>Tarih</th>
            <th>Müşteri</th>
            <th>Durum</th>
            <th class="text-end">Toplam</th>
            <th class="text-center">İşlem</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var s in Model)
        {
            var toplamTutar = s.Kalemler.Sum(k => k.Miktar * k.BirimFiyat * (1 - k.IndirimYuzde / 100));
            var durumClass = s.Durum == GurBoya.Models.SiparisDurumu.Tamamlandi ? "success" :
                             s.Durum == GurBoya.Models.SiparisDurumu.Iptal ? "danger" : "warning";
            <tr>
                <td>@s.Id</td>
                <td>@s.Tarih.ToString("dd.MM.yyyy HH:mm")</td>
                <td>@(s.Musteri?.Ad ?? "Perakende")</td>
                <td><span class="badge bg-@durumClass">@s.Durum</span></td>
                <td class="text-end">@toplamTutar.ToString("N2") ₺</td>
                <td class="text-center">
                    <a asp-action="Detail" asp-route-id="@s.Id" class="btn btn-sm btn-info">Detay</a>
                </td>
            </tr>
        }
    </tbody>
</table>