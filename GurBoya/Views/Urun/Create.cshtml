@model GurBoya.Models.Urun
@{
    ViewData["Title"] = "Yeni Ürün";
}

<h2>Yeni Ürün</h2>
<hr />

@if (TempData["Hata"] != null)
{
    <div class="alert alert-danger">@TempData["Hata"]</div>
}

<form asp-action="Create" method="post" class="row g-3">
    @Html.AntiForgeryToken()

    <div class="col-md-4">
        <label asp-for="Kod" class="form-label">Ürün Kodu</label>
        <input asp-for="Kod" class="form-control" />
        <span asp-validation-for="Kod" class="text-danger"></span>
    </div>
    <div class="col-md-8">
        <label asp-for="Ad" class="form-label">Ürün Adı</label>
        <input asp-for="Ad" class="form-control" />
        <span asp-validation-for="Ad" class="text-danger"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="KategoriId" class="form-label">Kategori</label>
        <select asp-for="KategoriId" asp-items="ViewBag.Kategoriler" class="form-select">
            <option value="">Seçiniz</option>
        </select>
    </div>
    <div class="col-md-4">
        <label asp-for="Birim" class="form-label">Birim</label>
        <select asp-for="Birim" class="form-select">
            <option value="adet">Adet</option>
            <option value="kg">Kg</option>
            <option value="lt">Litre</option>
            <option value="mt">Metre</option>
            <option value="kutu">Kutu</option>
        </select>
    </div>
    <div class="col-md-4">
        <label asp-for="KritikStokSeviyesi" class="form-label">Kritik Stok Seviyesi</label>
        <input asp-for="KritikStokSeviyesi" class="form-control" type="number" step="0.001" />
    </div>
    <div class="col-md-4">
        <label asp-for="AlisFiyati" class="form-label">Alış Fiyatı (₺)</label>
        <input asp-for="AlisFiyati" class="form-control" type="number" step="0.01" />
    </div>
    <div class="col-md-4">
        <label asp-for="SatisFiyati" class="form-label">Satış Fiyatı (₺)</label>
        <input asp-for="SatisFiyati" class="form-control" type="number" step="0.01" />
    </div>
    <div class="col-md-4">
        <label asp-for="StokMiktari" class="form-label">Başlangıç Stok</label>
        <input asp-for="StokMiktari" class="form-control" type="number" step="0.001" />
    </div>
    <div class="col-12">
        <label asp-for="Aciklama" class="form-label">Açıklama</label>
        <textarea asp-for="Aciklama" class="form-control" rows="2"></textarea>
    </div>
    <div class="col-12">
        <button type="submit" class="btn btn-primary">Kaydet</button>
        <a asp-action="Index" class="btn btn-secondary">İptal</a>
    </div>
</form>